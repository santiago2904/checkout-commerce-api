# ================================
# Example Terraform Variables File
# ================================
# Copy this file to terraform.tfvars and customize the values
# Command: cp terraform.tfvars.example terraform.tfvars

# Project Configuration
project_name = "checkout-commerce"
environment  = "prod"
aws_region   = "us-east-1"

# Database Configuration
db_instance_class        = "db.t3.micro" # Free tier eligible
db_name                  = "checkoutdb"
db_username              = "dbadmin"
db_password              = "o4(9w;M[BtHk23"
db_allocated_storage     = 20    # 20 GB is free tier eligible
db_backup_retention_days = 1     # Free Tier only allows 1 day
db_multi_az              = false # Set to false for cost savings (not free tier)
db_publicly_accessible   = true # Keep false for security

# ECR Configuration
ecr_image_tag_mutability = "MUTABLE"
ecr_scan_on_push         = true
ecr_lifecycle_max_images = 10

# Networking Configuration
vpc_cidr           = "10.0.0.0/16"
availability_zones = ["us-east-1a", "us-east-1b"]

# ECS Configuration
ecs_task_cpu      = 256       # 256 = 0.25 vCPU (Free tier eligible)
ecs_task_memory   = 512       # 512 MB
ecs_desired_count = 1         # Number of tasks to run
ecs_max_count     = 2         # Max for autoscaling
ecs_min_count     = 1         # Min for autoscaling
app_port          = 3000      # NestJS default port
health_check_path = "/api/health" # Health endpoint with global prefix
container_image   = "latest"  # Docker image tag

# Application Load Balancer
enable_alb              = true # Set to false to use public IP only (saves ALB costs)
alb_ssl_certificate_arn = ""   # Add your ACM certificate ARN for HTTPS

# Tags
tags = {
  Project     = "checkout-commerce"
  ManagedBy   = "Terraform"
  Environment = "prod"
  Owner       = "DevOps Team"
}

# Application Environment Variables (⚠️ CHANGE THESE VALUES!)
jwt_secret           = "wompitest"
jwt_expires_in       = "1h"
wompi_public_key     = "pub_stagtest_g2u0HQd3ZMh05hsSgTS2lUV8t3s4mOt7"
wompi_private_key    = "prv_stagtest_5i0ZGIGiFcDQifYsXxvsny7Y37tKqFWg"
wompi_api_url        = "https://api-sandbox.co.uat.wompi.dev/v1"  # Change to production URL when ready
wompi_events_secret  = "stagtest_events_2PDUmhMywUkvb1LvxYnayFbmofT7w39N"
frontend_url         = "http://mitienda"  # Change to your actual frontend URL
